# Public — safe to expose to the browser (Next.js inlines NEXT_PUBLIC_* at build time)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only — used by `npm run seed` (plain Node script, reads .env.local via dotenv).
# The Next.js app itself reads server secrets from `.dev.vars` / Worker secrets instead,
# see .dev.vars.example.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
